# Genny User Pod Image — runs inside each JupyterHub user pod
# Architecture: jupyterhub-singleuser on :8888 (required by JupyterHub)
#               Genny FastAPI + Next.js UI on :8889 (accessible via /user/{name}/proxy/8889/)
#               noVNC desktop on :6080 (accessible via /user/{name}/proxy/6080/)
# Base: JupyterHub compatible (jovyan user, uid 1000)

FROM quay.io/jupyter/base-notebook:hub-5.4.4

USER root

# System deps + VNC/desktop stack
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl build-essential \
    xvfb x11vnc xterm \
    novnc websockify \
    openbox \
    python3-tk \
    fonts-noto fonts-noto-color-emoji fonts-symbola \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && apt-get clean && rm -rf /var/lib/apt/lists/* \
    && fc-cache -fv

# Fontconfig: prefer Symbola for fallback so emoji/symbols render in tkinter/Xft
COPY k8s/jupyterhub/templates/fontconfig-fallback.conf /etc/fonts/conf.d/99-genny-fallback.conf

# Python deps (non-tkinter subset for server use)
COPY requirements-web.txt /tmp/requirements-web.txt
RUN pip install --no-cache-dir -r /tmp/requirements-web.txt

# Install the genny package
COPY --chown=jovyan:users . /opt/genny-platform
RUN pip install --no-cache-dir -e /opt/genny-platform

# Build Next.js frontend (static export to /opt/genny-platform/web/out)
WORKDIR /opt/genny-platform/web
RUN npm ci --prefer-offline && npm run build

# Startup script: runs Genny UI on :8889, noVNC on :6080, then exec's jupyterhub-singleuser
COPY scripts/start-genny-user.sh /usr/local/bin/start-genny-user.sh
RUN chmod +x /usr/local/bin/start-genny-user.sh

# ── GitHub CLI + Copilot CLI ──────────────────────────────────────────────────
# Install gh CLI and the standalone Copilot CLI into /opt/gh-tools (shared, root-owned).
# The genny wrapper at /usr/local/bin/genny calls copilot with the user's saved PAT.
RUN set -e \
    && GH_VER=$(curl -fsSL https://api.github.com/repos/cli/cli/releases/latest \
        | python3 -c "import sys,json; print(json.load(sys.stdin)['tag_name'][1:])") \
    && curl -fsSL "https://github.com/cli/cli/releases/download/v${GH_VER}/gh_${GH_VER}_linux_amd64.tar.gz" \
        | tar -xz -C /tmp \
    && install -m755 /tmp/gh_${GH_VER}_linux_amd64/bin/gh /usr/local/bin/gh \
    && rm -rf /tmp/gh_* \
    && curl -fsSL https://gh.io/copilot-install | INSTALL_DIR=/usr/local/bin bash \
    && chmod +x /usr/local/bin/copilot

# genny CLI wrapper — calls copilot with the user's saved PAT from ~/.genny/.env
COPY scripts/genny-cli.sh /usr/local/bin/genny
RUN chmod +x /usr/local/bin/genny

USER jovyan
WORKDIR /home/jovyan

ENV GENNY_PLATFORM_DIR=/opt/genny-platform
ENV OLLAMA_URL=http://ollama.genny-shared.svc.cluster.local:11434
ENV DISPLAY=:1

# JupyterHub overrides CMD with cmd: value — we set it in values.yaml
CMD ["start-genny-user.sh"]
