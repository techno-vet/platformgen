# Auger Platform Configuration Example
# Copy to ~/.auger/config.yaml and customize

# Display settings
display: ":1"
port: 6000
theme: "dark"
log_level: "INFO"
hot_reload: true

# Enabled widgets
widgets_enabled:
  - chat           # Ask Auger assistant
  - github         # GitHub PRs and repos
  - pods           # DataDog Kubernetes pods
  - cryptkeeper_lite  # Encryption tool
  - servicenow     # ServiceNow tickets
  - prospector     # CVE scanner

# GitHub configuration
github:
  token: "${GITHUB_TOKEN}"  # Set in ~/.auger/.env

# DataDog configuration
datadog:
  api_key: "${DATADOG_API_KEY}"
  app_key: "${DATADOG_APP_KEY}"
  site: "ddog-gov.com"

# ServiceNow configuration
servicenow:
  url: "https://gsassistprod.servicenowservices.com"
  cookies: "${SERVICENOW_COOKIES}"

# Pods widget configuration
pods:
  clusters:
    - assist-core-development
    - assist-core-staging
    - assist-core-production
  default_cluster: "assist-core-development"
  refresh_interval: 30
