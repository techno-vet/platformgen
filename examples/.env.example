# Auger Platform Environment Variables
# Copy to ~/.auger/.env and fill in your actual values
# This file should be kept secure (mode 0600)

# GitHub (Required for Ask Auger)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxx

# DataDog (Optional - can configure via Ask Auger)
DATADOG_API_KEY=xxxxxxxxxxxxx
DATADOG_APP_KEY=xxxxxxxxxxxxx

# ServiceNow (Optional - captured via auto-login)
SERVICENOW_COOKIES={"JSESSIONID": "xxx", "glide_session_store": "xxx"}
SERVICENOW_COOKIE_EXPIRY=2026-02-28T00:00:00

# Cryptkeeper Keys (Optional)
DEV_CRYPTKEEPER_KEY=your-dev-key
STAGING_CRYPTKEEPER_KEY=your-staging-key
PROD_CRYPTKEEPER_KEY=your-prod-key
