# Auger Platform - Prefill Template
#
# Copy this file to: ~/.auger/.env
# It is shared between the host CLI and the Docker container.
#
# Setup:
#   mkdir -p ~/.auger
#   cp .env.example ~/.auger/.env
#   chmod 600 ~/.auger/.env
#   vim ~/.auger/.env   # fill in only the values you already have

# GitHub Copilot / Ask Auger token (github.com)
# Get from: https://github.com/settings/personal-access-tokens
# Permission needed: Copilot requests (read-only)
GH_TOKEN=

# Enterprise GitHub token used by GitHub widget, Prospector, and HTTPS git flows
# Get from: https://github.helix.gsa.gov/settings/tokens
# Recommended scopes: repo, read:user
GHE_TOKEN=
GHE_URL=https://github.helix.gsa.gov

# Artifactory username (your FCS username, not email)
ARTIFACTORY_USERNAME=

# Artifactory Identity Token (preferred for Docker/image pulls)
# Get from: https://artifactory.helix.gsa.gov -> Profile / Authentication Settings
ARTIFACTORY_IDENTITY_TOKEN=

# Legacy Artifactory API key (optional only if your account still has one)
# Some JFrog environments have deprecated or hidden API key creation.
ARTIFACTORY_API_KEY=

# Rancher bearer token for cluster/pod tooling
# Get from: Rancher UI -> API Keys
RANCHER_BEARER_TOKEN=

# DataDog API keys
# Get from: DataDog -> Organization Settings -> API Keys / Application Keys
DATADOG_API_KEY=
DATADOG_APP_KEY=

# Jenkins API token
# Get from: https://jenkins-mcaas.helix.gsa.gov/ -> your user -> Configure -> API Token
JENKINS_API_TOKEN=

# Jira login is usually captured through the Jira widget login flow.
# Leave blank unless you were given a direct value to paste.
JIRA_API_TOKEN=
