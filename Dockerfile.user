# Genny Platform — User Personalization Layer
#
# Built locally by genny-launch.sh to match the host user's uid/gid.
# This eliminates ALL host↔container permission mismatches permanently.
#
# How it works:
#   1. Pull the base image from Artifactory (genny-platform:latest)
#   2. Create a user in the image with the host uid/gid
#   3. Bake AUGER_HOST_HOME into the image so entrypoint.sh uses correct paths
#
# NOTE: The base image now installs all pip packages system-wide (/usr/local/lib/).
# There is NO copy of /home/auger/ to the new user's home — that was the 10-15 min
# slow step. This build now completes in ~30 seconds (just useradd + dirs).
#
# Called automatically by genny-launch.sh — never run directly.
#
# To rebuild manually:
#   docker build -f Dockerfile.user \
#     --build-arg BASE_IMAGE=artifactory.helix.gsa.gov/gs-assist-docker-repo/genny-platform:latest \
#     --build-arg HOST_USER=$(whoami) \
#     --build-arg HOST_UID=$(id -u) \
#     --build-arg HOST_GID=$(id -g) \
#     -t genny-platform-$(whoami):latest .

ARG BASE_IMAGE=artifactory.helix.gsa.gov/gs-assist-docker-repo/genny-platform:latest
FROM ${BASE_IMAGE}

ARG HOST_USER=auger
ARG HOST_UID=1000
ARG HOST_GID=1000

# If the host uid differs from the baked 'auger' user (uid 1000), create a
# matching user with the correct uid/gid and a minimal home directory.
# All pip packages are already system-wide — no copy needed.
# Skip if HOST_UID=1000 — user is already 'auger', nothing to do.
#
# IMPORTANT: Override nsswitch.conf to 'files' only before useradd.
# Domain-joined WorkSpaces have large UIDs (e.g. 1454024703). Without this,
# useradd triggers NSS/LDAP lookups that hang indefinitely inside the container.
RUN if [ "${HOST_UID}" != "1000" ]; then \
      cp /etc/nsswitch.conf /etc/nsswitch.conf.bak; \
      printf 'passwd: files\ngroup: files\nshadow: files\nhosts: files dns\n' > /etc/nsswitch.conf; \
      groupadd -g ${HOST_GID} ${HOST_USER} 2>/dev/null || true; \
      useradd --no-log-init -u ${HOST_UID} -g ${HOST_GID} -m -s /bin/bash \
              -d /home/${HOST_USER} ${HOST_USER}; \
      mkdir -p /home/${HOST_USER}/.auger /home/${HOST_USER}/.kube \
               /home/${HOST_USER}/.config /home/${HOST_USER}/.local/bin; \
      chown -R ${HOST_UID}:${HOST_GID} /home/${HOST_USER}; \
      mv /etc/nsswitch.conf.bak /etc/nsswitch.conf; \
    fi

# Patch: exclude content_area.py from ui/ hot-reload loop to prevent SIGSEGV
# (reloading a live Tkinter widget class from a background thread → exit 139).
COPY auger/ui/hot_reload.py /home/auger/genny-platform/auger_baked/ui/hot_reload.py

# Bake host identity into image environment.
# entrypoint.sh and genny-launch.sh read these to construct correct paths.
ENV AUGER_HOST_USER=${HOST_USER}
ENV AUGER_HOST_UID=${HOST_UID}
ENV AUGER_HOST_HOME=/home/${HOST_USER}
ENV HOME=/home/${HOST_USER}
ENV PATH="/home/${HOST_USER}/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
